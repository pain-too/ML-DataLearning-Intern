# ==================== 1. 敏感配置文件（必须屏蔽） ====================
.env
*.env
qwen_key.env
.env.*

# ==================== 2. 科创项目文件夹规则 ====================
# 屏蔽 Python 缓存文件夹
科创项目/__pycache__/

# 屏蔽 IDE 配置文件
科创项目/.gitignore
科创项目/.idea/

# 屏蔽对话历史缓存（本地保留即可，不提交）
科创项目/chat_history/

# 屏蔽所有 CSV/Excel 数据文件，但保留你需要的内容
*.csv
*.xlsx
*.xls
# 例外规则：保留 generated_result 里的关键文件
!科创项目/generated_result/*.py
!科创项目/generated_result/*.prompt
!科创项目/generated_result/*.txt
!科创项目/generated_result/数据处理结果/*.png

# ==================== 3. study 文件夹规则 ====================
# 屏蔽 study 里的密钥文件和缓存
study/LangChain4.8-4.14/qwen_key.env
study/LangChain4.8-4.14/*.env
study/LangChain4.8-4.14/__pycache__/
study/LangChain4.8-4.14/*.log

# ==================== 4. Python 通用临时文件 ====================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
*.egg-info/
dist/
build/

# ==================== 5. IDE 和系统文件 ====================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ==================== 6. 虚拟环境 ====================
venv/
.venv/
env/
.env/
